<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + "  " : "")Kor Field Review Booking</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="~/Assets/logo.ico" />
    <link rel="stylesheet" href="~/css/site.css?v=mobilefix1" />
    @RenderSection("Styles", required: false)
</head>
@{
    var inspectorMode =
        string.Equals(
            ViewData["InspectorMode"]?.ToString(),
            "true",
            StringComparison.OrdinalIgnoreCase);
}
<body data-inspector="@(inspectorMode ? "true" : "false")">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header>
        <div class="header site-header">
            <a href="https://www.korstructural.com"
               target="_blank"
               rel="noopener noreferrer"
               class="logo-link">
                <img src="~/assets/logo.png"
                     alt="Kor Structural"
                     class="site-logo" />
            </a>
            <span class="site-title">Kor Field Review Booking Requests</span>
        </div>
    </header>
    @{
        var isAdmin =
        ViewContext.RouteData.Values["page"]?
        .ToString()?
        .StartsWith("/Admin", StringComparison.OrdinalIgnoreCase) == true;
    }

    @if (isAdmin)
    {
        <div id="main-content" class="admin-page-container">
            @RenderBody()
        </div>
    }
    else
    {
        <div id="main-content" class="content page-container">
            @RenderBody()
        </div>
    }

    <footer class="site-footer">
        <p>&copy; @DateTime.Now.Year Kor Structural</p>
    </footer>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
    <script>
    (function () {

        function updateModes() {

            const isMobile = window.matchMedia("(max-width: 1000px)").matches;

            if (isMobile) {
                document.body.classList.add("mobile-mode");
            } else {
                document.body.classList.remove("mobile-mode");
            }

            const inspectorFlag = document.body.dataset.inspector === "true";

            if (isMobile && inspectorFlag) {
                document.body.classList.add("inspector-mode");
            } else {
                document.body.classList.remove("inspector-mode");
            }
        }

        updateModes();
        window.addEventListener("resize", updateModes);

    })();
    </script>
</body>
</html>
