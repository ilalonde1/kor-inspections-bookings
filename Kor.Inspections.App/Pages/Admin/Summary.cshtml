@page "/admin/summary"
@using Kor.Inspections.App.Services 
@model Kor.Inspections.App.Pages.Admin.SummaryModel
<h2>Field Reviews for @Model.SelectedDate.ToString("yyyy-MM-dd")</h2>

    <p>
        This summary shows all non-cancelled bookings scheduled for the selected day,
        based on Kor's local time.
    </p>

    <div class="assign-inline" style="align-items:center; margin-bottom:14px; flex-direction:row; flex-wrap:wrap;">
        <a asp-page="./Summary"
           asp-route-date="@Model.SelectedDate.AddDays(-1).ToString("yyyy-MM-dd")"
           asp-route-sort="@Model.Sort"
           asp-route-dir="@Model.Dir"
           class="btn-smooth">Prev Day</a>
        <span><strong>@Model.SelectedDate.ToString("yyyy-MM-dd")</strong></span>
        <a asp-page="./Summary"
           asp-route-date="@Model.SelectedDate.AddDays(1).ToString("yyyy-MM-dd")"
           asp-route-sort="@Model.Sort"
           asp-route-dir="@Model.Dir"
           class="btn-smooth">Next Day</a>
        <form method="post" asp-page-handler="Email" style="margin:0;">
            <input type="hidden" name="Date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
            <button type="submit" class="btn-primary">
                Email Tomorrow's Summary
            </button>
        </form>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="admin-status-message">
            @Model.StatusMessage
        </div>
    }

    @if (!Model.Bookings.Any())
    {
        <p>No bookings are scheduled for that day.</p>
    }
    else
    {
        var hasUnassignedRows = Model.Bookings.Any(b =>
            string.Equals(b.AssignedTo, "Unassigned", StringComparison.OrdinalIgnoreCase));

        @if (hasUnassignedRows)
        {
            <div class="summary-unassigned-note">
                Highlighted rows are unassigned.
            </div>
        }

        <div class="admin-table-container">
            <div class="table-responsive-mobile">
            <table class="admin-table" style="text-align:left;">
                <thead>
                    <tr>
                        <th class="col-time">
                            <a asp-page="./Summary"
                               asp-route-sort="time"
                               asp-route-dir="@Model.ToggleDir("time")"
                               class="sort-link"
                               style="text-align:left; display:inline-block;">
                                Time ⇅
                            </a>
                        </th>
                        <th class="col-job">
                            <a asp-page="./Summary"
                               asp-route-sort="job"
                               asp-route-dir="@Model.ToggleDir("job")"
                               class="sort-link"
                               style="text-align:left; display:inline-block;">
                                Job # ⇅
                            </a>
                        </th>
                        <th class="col-address">
                            <a asp-page="./Summary"
                               asp-route-sort="address"
                               asp-route-dir="@Model.ToggleDir("address")"
                               class="sort-link"
                               style="text-align:left; display:inline-block;">
                                Site Address ⇅
                            </a>
                        </th>
                        <th class="col-contact">Contact</th>
                        <th class="col-assigned">
                            <a asp-page="./Summary"
                               asp-route-sort="assigned"
                               asp-route-dir="@Model.ToggleDir("assigned")"
                               class="sort-link"
                               style="text-align:left; display:inline-block;">
                                Assigned To ⇅
                            </a>
                        </th>
                        <th class="col-status">
                            <a asp-page="./Summary"
                               asp-route-sort="status"
                               asp-route-dir="@Model.ToggleDir("status")"
                               class="sort-link"
                               style="text-align:left; display:inline-block;">
                                Status ⇅
                            </a>
                        </th>
                        <th class="col-comments">
                            Comments
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.Bookings)
                    {
                        var isUnassigned = string.Equals(b.AssignedTo, "Unassigned", StringComparison.OrdinalIgnoreCase);
                        <tr class="summary-booking-row @(isUnassigned ? "summary-unassigned-row" : "")" data-booking-id="@b.BookingId">
                            <td>
                                @BookingDisplayHelper.GetTimeDisplay(
                                b.TimePreference,
                                        b.StartLocal,
                                        b.EndLocal)
                    </td>
                            <td>@b.ProjectNumber</td>
                            <td>@b.ProjectAddress</td>
                            <td>@b.ContactName (@b.ContactPhone)</td>
                            <td>@b.AssignedTo</td>
                            <td>@b.Status</td>
                            <td>@b.Comments</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>

        var inspectorGroups = Model.Bookings
            .Where(b =>
                !string.IsNullOrWhiteSpace(b.AssignedToValue) &&
                !string.Equals(b.AssignedTo, "Unassigned", StringComparison.OrdinalIgnoreCase))
            .GroupBy(b => b.AssignedToValue)
            .OrderBy(g => g.Key)
            .ToList();

        @if (inspectorGroups.Any())
        {
            <div class="summary-route-planner">
                <h3>Inspector Route Planner</h3>
                <p class="helper-text-muted">Stops are listed in time order. Navigate Route opens Google Maps in that order.</p>

                @foreach (var group in inspectorGroups)
                {
                    var orderedGroup = group
                        .OrderBy(x => x.RouteOrder ?? int.MaxValue)
                        .ThenBy(x => x.StartLocal)
                        .ThenBy(x => x.ProjectAddress, StringComparer.OrdinalIgnoreCase)
                        .ToList();
                    var inspectorEmail = group.Key ?? string.Empty;
                    var inspectorLabel = orderedGroup.FirstOrDefault()?.AssignedTo ?? inspectorEmail;

                    <section class="summary-route-card" data-inspector="@inspectorLabel" data-inspector-email="@inspectorEmail">
                        <div class="summary-route-head">
                            <h4>@inspectorLabel</h4>
                            <div class="summary-route-actions">
                                <form method="post" asp-page-handler="SaveRouteOrder" class="summary-route-order-form" style="display:inline;">
                                    <input type="hidden" name="Date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="request.InspectorEmail" value="@inspectorEmail" />
                                    <input type="hidden" name="request.OrderedBookingIds" value="" />
                                    <button type="submit" class="btn-smooth summary-save-route-btn">Save Route Order</button>
                                </form>
                                <form method="post" asp-page-handler="EmailRoute" class="summary-route-email-form" style="display:inline;">
                                    <input type="hidden" name="Date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="request.InspectorEmail" value="@inspectorEmail" />
                                    <input type="hidden" name="request.OrderedBookingIds" value="" />
                                    <button type="submit" class="btn-smooth summary-email-route-btn">Email This Route</button>
                                </form>
                                <button type="button" class="btn-smooth summary-nav-route-btn">Navigate Route</button>
                            </div>
                        </div>

                        <ul class="summary-route-list">
                            @foreach (var b in orderedGroup)
                            {
                                <li class="summary-route-item"
                                    draggable="true"
                                    data-booking-id="@b.BookingId"
                                    data-address="@b.ProjectAddress">
                                    <span class="summary-route-time">
                                        @BookingDisplayHelper.GetTimeDisplay(
                                            b.TimePreference,
                                            b.StartLocal,
                                            b.EndLocal)
                                    </span>
                                    <span class="summary-route-job">@b.ProjectNumber</span>
                                    <span class="summary-route-address">@b.ProjectAddress</span>
                                </li>
                            }
                        </ul>
                    </section>
                }
            </div>
        }
    }

    <p class="summary-back-link">
        <a asp-page="/Admin/Index" class="btn-smooth">
            Back to Admin Dashboard
        </a>
        <a asp-page="/Admin/TrustedDomains" class="btn-smooth" style="margin-left:8px;">
            Manage Trusted Domains
        </a>

    </p>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const cards = Array.from(document.querySelectorAll(".summary-route-card"));
    if (!cards.length) return;

    cards.forEach((card) => {
        const list = card.querySelector(".summary-route-list");
        const navBtn = card.querySelector(".summary-nav-route-btn");
        const saveForm = card.querySelector(".summary-route-order-form");
        const emailForm = card.querySelector(".summary-route-email-form");
        const tableRows = Array.from(document.querySelectorAll(".summary-booking-row"));
        let draggedItem = null;

        if (!list) return;

        function getItems() {
            return Array.from(list.querySelectorAll(".summary-route-item"));
        }

        function getOrderedBookingIds() {
            return getItems()
                .map(i => (i.dataset.bookingId || "").trim())
                .filter(Boolean)
                .join(",");
        }

        function syncRouteForms() {
            const orderedIds = getOrderedBookingIds();
            [saveForm, emailForm].forEach((form) => {
                const input = form?.querySelector('input[name="request.OrderedBookingIds"]');
                if (input) input.value = orderedIds;
            });
        }

        getItems().forEach((item) => {
            item.addEventListener("click", function () {
                const bookingId = item.dataset.bookingId;
                if (!bookingId) return;

                getItems().forEach(i => i.classList.remove("active"));
                item.classList.add("active");

                tableRows.forEach(r => r.classList.remove("desktop-active-row"));
                const targetRow = document.querySelector(`.summary-booking-row[data-booking-id="${bookingId}"]`);
                if (targetRow) {
                    targetRow.classList.add("desktop-active-row");
                    targetRow.scrollIntoView({ behavior: "smooth", block: "center" });
                }
            });

            item.addEventListener("dragstart", function (event) {
                draggedItem = item;
                item.classList.add("summary-route-dragging");
                if (event.dataTransfer) {
                    event.dataTransfer.effectAllowed = "move";
                    event.dataTransfer.setData("text/plain", item.dataset.bookingId || "");
                }
            });

            item.addEventListener("dragend", function () {
                item.classList.remove("summary-route-dragging");
                draggedItem = null;
                syncRouteForms();
            });
        });

        list.addEventListener("dragover", function (event) {
            if (!draggedItem) return;
            event.preventDefault();

            const targetItem = event.target.closest(".summary-route-item");
            if (!targetItem || targetItem === draggedItem) return;

            const targetRect = targetItem.getBoundingClientRect();
            const insertAfter = event.clientY > targetRect.top + (targetRect.height / 2);

            if (insertAfter) {
                if (targetItem.nextSibling !== draggedItem) {
                    list.insertBefore(draggedItem, targetItem.nextSibling);
                }
            } else if (targetItem !== draggedItem.nextSibling) {
                list.insertBefore(draggedItem, targetItem);
            }
        });

        list.addEventListener("drop", function (event) {
            if (!draggedItem) return;
            event.preventDefault();
            syncRouteForms();
        });

        syncRouteForms();

        if (navBtn) {
            navBtn.addEventListener("click", function () {
                const addresses = getItems()
                    .map(i => (i.dataset.address || "").trim())
                    .filter(Boolean);

                if (!addresses.length) {
                    return;
                }

                const origin = encodeURIComponent(addresses[0]);
                const destination = encodeURIComponent(addresses[addresses.length - 1]);
                const waypoints = addresses.slice(1, -1).map(encodeURIComponent).join("|");

                const url =
                    "https://www.google.com/maps/dir/?api=1"
                    + "&origin=" + origin
                    + "&destination=" + destination
                    + (waypoints ? "&waypoints=" + waypoints : "");

                window.open(url, "_blank");
            });
        }
    });
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll("[data-inline-confirm-form]").forEach(function (form) {
        const trigger = form.querySelector("[data-confirm-trigger]");
        const label = form.querySelector("[data-confirm-label]");
        const controls = form.querySelector("[data-confirm-controls]");
        const cancel = form.querySelector("[data-confirm-cancel]");

        if (!trigger || !label || !controls || !cancel) return;

        trigger.addEventListener("click", function () {
            trigger.disabled = true;
            label.hidden = true;
            controls.hidden = false;
            controls.style.display = "inline-flex";
            controls.querySelector('button[type="submit"]')?.focus();
        });

        cancel.addEventListener("click", function () {
            controls.hidden = true;
            label.hidden = false;
            trigger.disabled = false;
            trigger.focus();
        });
    });
});
</script>
